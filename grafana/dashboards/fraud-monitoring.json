  "panels": [
    {
      "type": "stat",
      "title": "total predictions",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "datasource": {"type": "postgres", "uid": "efjvnrfskq1vke"},
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT COUNT(*) FROM prediction_logs WHERE ts >= $__timeFrom() AND ts <= $__timeTo()",
        "format": "table"
      }],
      "options": {"colorMode": "value", "graphMode": "none"}
    },
    {
      "type": "stat",
      "title": "fraud flagged rate (%)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "datasource": {"type": "postgres", "uid": "efjvnrfskq1vke"},
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 2) AS value FROM prediction_logs WHERE ts >= $__timeFrom() AND ts <= $__timeTo()",
        "format": "table"
      }],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "type": "stat",
      "title": "avg latency (ms)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "datasource": {"type": "postgres", "uid": "efjvnrfskq1vke"},
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT ROUND(AVG(latency_ms)::numeric, 1) FROM prediction_logs WHERE ts >= $__timeFrom() AND ts <= $__timeTo()",
        "format": "table"
      }],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "type": "stat",
      "title": "p95 latency (ms)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "datasource": {"type": "postgres", "uid": "efjvnrfskq1vke"},
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY latency_ms)::numeric, 1) FROM prediction_logs WHERE ts >= $__timeFrom() AND ts <= $__timeTo()",
        "format": "table"
      }],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "type": "timeseries",
      "title": "predictions per minute",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "datasource": {"type": "postgres", "uid": "efjvnrfskq1vke"},
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT date_trunc('minute', ts) AS time, COUNT(*) AS requests FROM prediction_logs WHERE ts >= $__timeFrom() AND ts <= $__timeTo() GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }]
    },
    {
      "type": "timeseries",
      "title": "avg fraud probability over time",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "datasource": {"type": "postgres", "uid": "efjvnrfskq1vke"},
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT date_trunc('minute', ts) AS time, AVG(fraud_probability) AS avg_proba FROM prediction_logs WHERE ts >= $__timeFrom() AND ts <= $__timeTo() GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }]
    },
    {
      "type": "timeseries",
      "title": "p95 latency over time (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "datasource": {"type": "postgres", "uid": "efjvnrfskq1vke"},
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT date_trunc('minute', ts) AS time, PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY latency_ms) AS p95_latency FROM prediction_logs WHERE ts >= $__timeFrom() AND ts <= $__timeTo() GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }]
    },
    {
      "type": "table",
      "title": "traffic by model version",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "datasource": {"type": "postgres", "uid": "efjvnrfskq1vke"},
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT model_run_id, COUNT(*) AS requests, ROUND(AVG(fraud_probability)::numeric, 4) AS avg_proba, ROUND(AVG(latency_ms)::numeric, 1) AS avg_ms FROM prediction_logs WHERE ts >= $__timeFrom() AND ts <= $__timeTo() GROUP BY model_run_id ORDER BY requests DESC",
        "format": "table"
      }]
    }
  ],
